  "keyFeatures": [
    "YAML-driven config for the full fine-tuning pipeline",
    "SFT, LoRA, QLoRA, full fine-tuning support",
    "Preference tuning: DPO, IPO, KTO, ORPO, GDPO",
    "Reinforcement learning: GRPO, EBFT with vLLM async generation",
    "Reward modelling and process reward modelling (PRM)",
    "Multimodal/VLM fine-tuning (LLaMA-Vision, Qwen2-VL, Pixtral, Gemma, etc.)",
    "Multi-GPU training via DeepSpeed, FSDP1, FSDP2",
    "Multi-node training via Torchrun and Ray",
    "Performance optimizations: Flash Attention, sample packing, LoRA optims",
    "Flexible dataset loading from local, HuggingFace, S3, GCS, Azure, OCI",
    "Docker images and PyPI packages for cloud and local hardware",
    "Quantization Aware Training (QAT) and FP8 fine-tuning"
  ],
  "publicApiSurface": [
    "axolotl train <config.yaml>",
